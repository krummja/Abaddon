[sub_resource type="VisualShaderNodeExpression" id="VisualShaderNodeExpression_213io"]
size = Vector2(600, 460)
expression = "vec2 xDiv = dFdx(pos);
vec2 yDiv = dFdx(pos);

vec2 threshold = (abs(xDiv) + abs(yDiv)) * thickness * 0.5 / unit;
vec2 posWrapped = pos / unit;
vec2 line =
	step(fract(-posWrapped), threshold) +
	step(fract( posWrapped), threshold);
	
grid = max(line.x, line.y);"

